# Copy to .env and fill in. Generate keys with: openssl rand -hex 32
MASTER_KEY=          # 32-byte hex key used to AES-256-GCM encrypt stored passwords. KEEP SECRET. Losing it = losing all stored passwords.
JWT_SECRET=          # 32-byte hex secret for signing session tokens
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=      # Initial admin password (only used on first run to seed the admin account)
PORT=3000
